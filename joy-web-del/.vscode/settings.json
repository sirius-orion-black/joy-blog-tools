{
  // 强制使用空格进行缩进
  "editor.insertSpaces": true,

  // 定义缩进的空格数，例如 2 或 4
  "editor.tabSize": 2,

  // 【关键】关闭自动检测，防止 VS Code 根据文件内容覆盖以上设置
  "editor.detectIndentation": false,

  // 可选：保存时自动格式化代码，需配合 Prettier 等插件
  "editor.formatOnSave": true,

  // 在 Prettier 中设置使用双引号
  "prettier.singleQuote": false,
  // 或者更明确地设置使用双引号
  "prettier.quoteProps": "as-needed",
  // 如果使用 ESLint，也可以通过此设置确保双引号
}