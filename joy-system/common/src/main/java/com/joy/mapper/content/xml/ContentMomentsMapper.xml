<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.joy.mapper.content.ContentMomentsMapper">

    <resultMap id="MomentsWithLabelsResultMap" type="com.joy.entity.content.ContentMoments">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="content" property="content"/>
        <result column="image_urls" property="imageUrls"/>
        <result column="video_url" property="videoUrl"/>
        <result column="privacy" property="privacy"/>
        <result column="state" property="state"/>
        <result column="location" property="location"/>
        <result column="user_source" property="userSource"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <!-- 标签信息 -->
        <result column="label_ids" property="labels" typeHandler="com.joy.handler.StringToLongListTypeHandler"/>
        <result column="label_names" property="labelNames" typeHandler="com.joy.handler.StringToListTypeHandler"/>
    </resultMap>

    <!-- 查询列表，含标签信息 -->
    <select id="selectMomentsWithLabels" resultMap="MomentsWithLabelsResultMap">
        SELECT m.*,
        GROUP_CONCAT(ml.label_id) as label_ids,
        GROUP_CONCAT(cl.name) as label_names
        FROM content_moments m
        LEFT JOIN content_moments_label ml ON m.id = ml.moments_id
        LEFT JOIN content_label cl ON ml.label_id = cl.id
        WHERE m.state != 2              <!-- 不查询删除状态 -->
        AND m.privacy != 3              <!-- 不查询私密 -->
        <if test="userIds != null and userIds.size() > 0">
            AND m.user_id IN
            <foreach collection='userIds' item='userId' open='(' separator=',' close=')'>
                #{userId}
            </foreach>
        </if>
        GROUP BY m.id
        ORDER BY m.create_time DESC
    </select>

    <!-- 查询列表，含标签信息 -->
    <select id="selectMomentsPublishPublicly" resultMap="MomentsWithLabelsResultMap">
        SELECT m.*,
        GROUP_CONCAT(ml.label_id) as label_ids,
        GROUP_CONCAT(cl.name) as label_names
        FROM content_moments m
        LEFT JOIN content_moments_label ml ON m.id = ml.moments_id
        LEFT JOIN content_label cl ON ml.label_id = cl.id
        WHERE m.state = 1              <!-- 查询发布 -->
        AND m.privacy = 1              <!-- 查询公开 -->
        GROUP BY m.id
        ORDER BY m.create_time DESC
    </select>

</mapper>